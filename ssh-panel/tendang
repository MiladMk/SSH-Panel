#!/bin/bash
# Optimized for Ubuntu 24.04 — Multi-Port Support
clear

# حد مجاز پیش‌فرض تعداد اتصالات (کانکشن) برای هر کاربر
MAX=1

# اگر مقداری به عنوان آرگومان به اسکریپت پاس داده شود، آن را به عنوان MAX در نظر می‌گیرد
if [[ ${1+x} ]]; then
        MAX=$1
fi

# آرایه‌ای برای ذخیره تعداد اتصالات و PIDهای هر کاربر
declare -A user_connections
declare -A user_pids

# ۱. جمع‌آوری اطلاعات کاربران آنلاین Dropbear (مستقل از پورت)
# پیدا کردن تمامی PIDهای فعال سرویس dropbear
all_dropbear_pids=$(ps -C dropbear -o pid=)

for PID in $all_dropbear_pids; do
    # بررسی سلسله‌مراتب پروسه‌ها (پروسه فرزند والدش بزرگتر از ۱ است)
    PPID_NUM=$(ps -o ppid= -p $PID | tr -d ' ')
    
    if [ ! -z "$PPID_NUM" ] && [ "$PPID_NUM" -gt 1 ]; then
        # استخراج نام کاربری واقعی از Journal سیستم بدون نیاز به auth.log
        LOG_LINE=$(journalctl _PID=$PID --no-pager 2>/dev/null | grep -i "Password auth succeeded" | tail -n 1)
        
        if [ ! -z "$LOG_LINE" ]; then
            USER=$(echo "$LOG_LINE" | awk -F"for '" '{print $2}' | cut -d"'" -f1)
            
            if [ ! -z "$USER" ] && [ "$USER" != "root" ]; then
                # شمارش کانکشن‌ها و ذخیره PIDها برای این کاربر
                user_connections["$USER"]=$(( ${user_connections["$USER"]:-0} + 1 ))
                user_pids["$USER"]="${user_pids["$USER"]} $PID"
            fi
        fi
    fi
done

# ۲. جمع‌آوری اطلاعات کاربران آنلاین OpenSSH (مستقل از پورت)
# پیدا کردن پروسه‌های فرزند SSH بدون نیاز به تگ [priv] یا وابستگی به لاگ
ssh_pids=$(ps aux | grep "sshd" | grep -v -E "grep|sshd -D" | awk '{print $2}')

for PID in $ssh_pids; do
    USER=$(ps -o user= -p $PID)
    
    if [ ! -z "$USER" ] && [ "$USER" != "root" ] && [ "$USER" != "sshd" ] && [ "$USER" != "reboot" ]; then
        # شمارش کانکشن‌ها و ذخیره PIDها برای این کاربر
        user_connections["$USER"]=$(( ${user_connections["$USER"]:-0} + 1 ))
        user_pids["$USER"]="${user_pids["$USER"]} $PID"
    fi
done

# ۳. بررسی تخلفات و اعمال محدودیت (Kill متخلفین)
KILLED_COUNT=0

for USER in "${!user_connections[@]}"; do
    COUNT=${user_connections["$USER"]}
    
    # اگر تعداد اتصالات کاربر روی تمام پورت‌ها بیشتر از حد مجاز بود
    if [ $COUNT -gt $MAX ]; then
        CURRENT_DATE=$(date +"%Y-%m-%d %X")
        
        # نمایش اطلاعات کاربر متخلف در خروجی و ذخیره در فایل لاگ پروژه
        echo "$CURRENT_DATE - User: $USER has $COUNT connections (Max allowed: $MAX). Killing..."
        echo "$CURRENT_DATE - $USER - $COUNT" >> /root/log-limit.txt
        
        # قطع کردن تمام اتصالات این کاربر متخلف به صورت یکجا
        kill ${user_pids["$USER"]} 2>/dev/null
        KILLED_COUNT=$((KILLED_COUNT + 1))
    fi
done

# اگر کاربری ریستکت و قطع اتصال شد، برای پایداری بهتر نیازی به ریست کل سرویس نیست،
# اما ساختار قدیمی شما را برای هماهنگی با پنل حفظ کردیم.
if [ $KILLED_COUNT -gt 0 ]; then
    systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null
    systemctl restart dropbear 2>/dev/null
fi
